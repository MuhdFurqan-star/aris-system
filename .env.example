# Copy this file to .env for local development
# On Railway, set these as environment variables in the dashboard

DEBUG=False
SECRET_KEY=your-very-secret-key-here-change-this

# Railway sets this automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/dbname

ALLOWED_HOSTS=yourdomain.railway.app
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app

# Registration access codes (change these!)
LECTURER_SECRET_CODE=LECTURER2024
ADMIN_SECRET_CODE=ADMIN2024

# Email (optional — set up Gmail SMTP for real email notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
